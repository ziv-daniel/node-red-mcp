# Production environment — copy to .env.prod and fill in real values

# Node-RED (running as HA add-on behind Cloudflare Tunnel)
NODERED_URL=https://nodered.danielshaprvt.work

# Public URL of this MCP server — used in OAuth discovery
PUBLIC_URL=https://mcp.danielshaprvt.work

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# CORS
CORS_ORIGIN=https://claude.ai

# Logging
LOG_LEVEL=info
